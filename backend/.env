# Server
PORT=5000
NODE_ENV=development

# MongoDB (local)
MONGO_URI=mongodb://localhost:27017/unicanteen

# JWT
JWT_SECRET=unicanteen_dev_secret_change_in_production_32chars
JWT_EXPIRE=7d

# Razorpay (replace with your test keys from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email (optional - leave blank to skip)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
